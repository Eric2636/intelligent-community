<nav title-text="{{task ? task.title : '任务详情'}}" show-back="{{true}}" />
<view class="detail-page">
  <view wx:if="{{loading}}" class="detail-loading"><t-loading theme="dots" size="48rpx" /></view>
  <block wx:elif="{{task}}">
    <view class="detail-card">
      <view class="detail-card__reward">佣金 ¥{{task.reward}}</view>
      <view class="detail-card__tag detail-card__tag--{{task.status}}">{{STATUS_TEXT[task.status]}}</view>
      <view class="detail-card__title">{{task.title}}</view>
      <view class="detail-card__desc" wx:if="{{task.desc}}">{{task.desc}}</view>
      <view class="detail-card__media" wx:if="{{task.images.length || task.videos.length}}">
        <view class="detail-card__media-grid">
          <block wx:for="{{task.images}}" wx:key="*this">
            <image
              class="detail-card__media-img"
              src="{{item}}"
              mode="aspectFill"
              data-current="{{item}}"
              bindtap="onPreviewTaskImages"
            />
          </block>
          <block wx:for="{{task.videos}}" wx:key="*this">
            <video
              class="detail-card__media-video"
              src="{{item}}"
              controls
              show-center-play-btn
              object-fit="contain"
            />
          </block>
        </view>
      </view>
      <view class="detail-card__row"><text class="detail-card__label">地点</text>{{task.location}}</view>
      <view class="detail-card__row"><text class="detail-card__label">发布者</text>{{task.publisherName}}</view>
      <view class="detail-card__row" wx:if="{{task.takerName}}"><text class="detail-card__label">接单人</text>{{task.takerName}}</view>
      <view class="detail-card__row"><text class="detail-card__label">发布时间</text>{{task.createdAt}}</view>
      <view wx:if="{{task.status === 'in_progress' && task.claimedAt}}" class="detail-card__row"><text class="detail-card__label">领取时间</text>{{task.claimedAt}}</view>
      <view wx:if="{{task.proofText}}" class="detail-card__proof">
        <text class="detail-card__label">完成说明</text>
        <text>{{task.proofText}}</text>
        <text class="detail-card__time" wx:if="{{task.completedAt}}">{{task.completedAt}}</text>
      </view>
    </view>

    <view class="detail-actions">
      <block wx:if="{{task.status === 'draft' && isPublisher}}">
        <t-button theme="primary" size="large" block bindtap="onPublishDraft">发布任务</t-button>
        <t-button theme="default" size="large" block bindtap="onDeleteTask" style="margin-top: 16rpx;">删除草稿</t-button>
        <view class="detail-actions__hint">提示：草稿不会出现在大厅，发布后他人才能领取。</view>
      </block>
      <block wx:elif="{{task.status === 'pending_take' && !isPublisher}}">
        <t-button theme="primary" size="large" block bindtap="onClaim">领取任务</t-button>
        <view class="detail-actions__hint">提示：领取后你将成为接单人，需要完成任务并提交完成说明。</view>
      </block>
      <block wx:elif="{{task.status === 'in_progress' && isTaker}}">
        <view class="detail-proof">
          <textarea placeholder="请填写完成说明（必填）" value="{{proofText}}" bindinput="onProofInput" class="detail-proof__input" />
          <t-button theme="primary" size="large" block bindtap="onSubmitComplete">提交完成</t-button>
          <t-button theme="default" size="large" block bindtap="onAbandon" style="margin-top: 16rpx;">放弃任务</t-button>
        </view>
        <view class="detail-actions__hint">提示：你也可以放弃任务，任务将重新回到待领取。</view>
      </block>
      <block wx:elif="{{task.status === 'pending_confirm' && isPublisher}}">
        <t-button theme="primary" size="large" block bindtap="onConfirmComplete">确认完成</t-button>
        <view class="detail-actions__hint">提示：确认完成前请先与接单人线下结算赏金。</view>
      </block>
      <block wx:elif="{{task.status === 'pending_take' && isPublisher}}">
        <t-button theme="default" size="large" block bindtap="onCancel">撤销发布</t-button>
        <view class="detail-actions__hint">提示：撤销发布后该任务将不再可领取。</view>
      </block>
      <block wx:elif="{{task.status === 'cancelled' && isPublisher}}">
        <t-button theme="primary" size="large" block bindtap="onRepublish">重新发布</t-button>
        <t-button theme="default" size="large" block bindtap="onDeleteTask" style="margin-top: 16rpx;">删除任务</t-button>
        <view class="detail-actions__hint">提示：已撤销的任务可以重新发布；删除后不可恢复。</view>
      </block>
      <block wx:elif="{{task.status === 'completed' && (isPublisher || isTaker) && otherPartyId}}">
        <t-button theme="primary" size="large" block bindtap="onOpenRating">评价 {{otherPartyName}}</t-button>
        <view class="detail-actions__hint">提示：评价仅用于展示信用，不涉及支付。</view>
      </block>
    </view>

    <view wx:if="{{showRating}}" class="detail-rating-mask" catchtap="onCloseRating">
      <view class="detail-rating-panel" catchtap="">
        <view class="detail-rating__title">评价 {{otherPartyName}}</view>
        <view class="detail-rating__stars">
          <text class="detail-rating__star {{ratingScore >= 1 ? 'on' : ''}}" data-score="1" bindtap="onRatingStar">★</text>
          <text class="detail-rating__star {{ratingScore >= 2 ? 'on' : ''}}" data-score="2" bindtap="onRatingStar">★</text>
          <text class="detail-rating__star {{ratingScore >= 3 ? 'on' : ''}}" data-score="3" bindtap="onRatingStar">★</text>
          <text class="detail-rating__star {{ratingScore >= 4 ? 'on' : ''}}" data-score="4" bindtap="onRatingStar">★</text>
          <text class="detail-rating__star {{ratingScore >= 5 ? 'on' : ''}}" data-score="5" bindtap="onRatingStar">★</text>
        </view>
        <textarea placeholder="选填评价内容" value="{{ratingComment}}" bindinput="onRatingComment" class="detail-rating__input" />
        <t-button theme="primary" size="medium" block bindtap="onSubmitRating">提交评价</t-button>
      </view>
    </view>
  </block>
  <view wx:else class="detail-loading">任务不存在</view>
</view>
