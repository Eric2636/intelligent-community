<view class="my-tasks-page">
  <t-tabs value="{{activeTab}}" bind:change="onTabChange" space-evenly>
    <t-tab-panel wx:for="{{tabs}}" wx:key="value" label="{{item.label}}" value="{{item.value}}" />
  </t-tabs>

  <view class="tab-content">
    <t-pull-down-refresh
      value="{{loading}}"
      loadingProps="{{loadingProps}}"
      bind:refresh="onPullDownRefresh"
    >
      <view wx:if="{{activeTab === 'published'}}">
        <view class="task-list">
          <t-cell
            wx:for="{{publishedList}}"
            wx:key="id"
            title="{{item.title}}"
            note="佣金：{{item.reward}}元"
            hover
            bind:click="goDetail"
            data-id="{{item.id}}"
          >
            <view slot="note" class="task-info">
              <t-tag theme="primary" size="small">{{STATUS_TEXT[item.status]}}</t-tag>
              <text class="reward">佣金：{{item.reward}}元</text>
            </view>
          </t-cell>
        </view>
        <t-empty wx:if="{{!loading && publishedList.length === 0}}" description="暂无发布的任务" />
      </view>

      <view wx:if="{{activeTab === 'taken'}}">
        <view class="task-list">
          <t-cell
            wx:for="{{takenList}}"
            wx:key="id"
            title="{{item.title}}"
            note="佣金：{{item.reward}}元"
            hover
            bind:click="goDetail"
            data-id="{{item.id}}"
          >
            <view slot="note" class="task-info">
              <t-tag theme="primary" size="small">{{STATUS_TEXT[item.status]}}</t-tag>
              <text class="reward">佣金：{{item.reward}}元</text>
            </view>
          </t-cell>
        </view>
        <t-empty wx:if="{{!loading && takenList.length === 0}}" description="暂无领取的任务" />
      </view>
    </t-pull-down-refresh>
  </view>
</view>
