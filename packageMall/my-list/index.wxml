<view class="my-list-page">
  <t-pull-down-refresh
    value="{{loading}}"
    loadingProps="{{loadingProps}}"
    bind:refresh="onPullDownRefresh"
  >
    <view class="item-grid">
      <view class="item-card" wx:for="{{itemList}}" wx:key="id" bind:tap="goDetail" data-id="{{item.id}}">
        <image class="item-image" src="{{item.image || '/static/default-item.png'}}" mode="aspectFill" lazy-load />
        <view class="item-info">
          <view class="item-title">{{item.title}}</view>
          <view class="item-price">¥{{item.price}}</view>
          <view class="item-category">{{item.categoryName}}</view>
        </view>
      </view>
    </view>
    <t-empty wx:if="{{!loading && itemList.length === 0}}" description="暂无发布的商品" />
  </t-pull-down-refresh>
</view>
