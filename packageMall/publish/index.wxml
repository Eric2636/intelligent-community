<nav title-text="发布" show-back="{{true}}" />
<view class="publish-page">
  <view class="publish-form">
    <view class="publish-field">
      <view class="publish-field__label">分类</view>
      <picker mode="selector" range="{{categories}}" range-key="name" value="{{categoryIndex}}" bindchange="onCategoryChange">
        <view class="publish-field__picker">{{categoryName}}</view>
      </picker>
    </view>
    <view class="publish-field">
      <input
        class="publish-field__input"
        placeholder="标题（必填）"
        value="{{title}}"
        maxlength="40"
        bindinput="onTitleInput"
      />
    </view>
    <view class="publish-field">
      <input
        class="publish-field__input"
        type="digit"
        placeholder="价格（选填，元）"
        value="{{price}}"
        bindinput="onPriceInput"
      />
    </view>
    <view class="publish-field">
      <textarea
        class="publish-field__input publish-field__textarea"
        placeholder="描述（选填）"
        value="{{desc}}"
        maxlength="500"
        bindinput="onDescInput"
      />
    </view>
    <view class="publish-field">
      <input
        class="publish-field__input"
        placeholder="联系方式（选填）"
        value="{{contact}}"
        bindinput="onContactInput"
      />
    </view>

    <view class="publish-field">
      <view class="publish-field__label">主图（用于列表展示，必填 1 张）</view>
      <view class="media-picker" wx:if="{{mainImages.length}}">
        <view class="media-picker__grid">
          <block wx:for="{{mainImages}}" wx:for-index="idx" wx:key="*this">
            <view class="media-picker__cell">
              <image
                class="media-picker__img"
                src="{{item}}"
                mode="aspectFill"
                data-urls="{{mainImages}}"
                data-current="{{item}}"
                bindtap="onPreviewImage"
              />
              <view class="media-picker__del" data-kind="main" data-index="{{idx}}" catchtap="onRemoveMedia">×</view>
            </view>
          </block>
        </view>
      </view>
      <view class="media-picker__add" bindtap="onAddMainImages" wx:if="{{mainImages.length < 1 && mainImages.length + subImages.length < 6}}">
        + 添加主图
      </view>
    </view>

    <view class="publish-field">
      <view class="publish-field__label">副图（详情轮播，主图+副图合计最多 6 张）</view>
      <view class="media-picker" wx:if="{{subImages.length}}">
        <view class="media-picker__grid">
          <block wx:for="{{subImages}}" wx:for-index="idx" wx:key="*this">
            <view class="media-picker__cell">
              <image
                class="media-picker__img"
                src="{{item}}"
                mode="aspectFill"
                data-urls="{{subImages}}"
                data-current="{{item}}"
                bindtap="onPreviewImage"
              />
              <view class="media-picker__del" data-kind="sub" data-index="{{idx}}" catchtap="onRemoveMedia">×</view>
            </view>
          </block>
        </view>
      </view>
      <view class="media-picker__add" bindtap="onAddSubImages" wx:if="{{mainImages.length + subImages.length < 6}}">
        + 添加副图
      </view>
    </view>

    <view class="publish-field">
      <view class="publish-field__label">视频（最多 2 段）</view>
      <view class="media-picker" wx:if="{{videos.length}}">
        <view class="media-picker__grid">
          <block wx:for="{{videos}}" wx:for-index="vidx" wx:key="*this">
            <view class="media-picker__cell media-picker__cell--video">
              <video class="media-picker__video" src="{{item}}" object-fit="cover" show-center-play-btn="{{true}}" controls="{{false}}" />
              <view class="media-picker__del" data-kind="video" data-index="{{vidx}}" catchtap="onRemoveMedia">×</view>
            </view>
          </block>
        </view>
      </view>
      <view class="media-picker__add" bindtap="onAddVideos" wx:if="{{videos.length < 2}}">
        + 添加视频
      </view>
    </view>
    <t-button class="publish-submit" theme="primary" size="large" block bindtap="submit" loading="{{submitting}}">
      发布
    </t-button>
  </view>
</view>
