<nav title-text="商城" />
<view class="mall-page">
  <view class="mall-search">
    <view class="mall-search__bar">
      <t-icon name="search" size="40rpx" class="mall-search__icon" />
      <t-input
        class="mall-search__input"
        placeholder="搜索商品标题、描述"
        value="{{keyword}}"
        clearable
        bindchange="onSearchInput"
        bindconfirm="onSearchConfirm"
      />
      <view class="mall-search__btn" bindtap="onSearchConfirm">搜索</view>
    </view>
  </view>
  <view class="mall-order">
    <view class="mall-order__item {{orderBy === 'time' ? 'mall-order__item--active' : ''}}" data-order="time" bindtap="onOrderChange">最新</view>
    <view class="mall-order__item {{orderBy === 'price_asc' ? 'mall-order__item--active' : ''}}" data-order="price_asc" bindtap="onOrderChange">价格升序</view>
    <view class="mall-order__item {{orderBy === 'price_desc' ? 'mall-order__item--active' : ''}}" data-order="price_desc" bindtap="onOrderChange">价格降序</view>
  </view>
  <view class="mall-category">
    <view class="mall-category__label">分类</view>
    <view class="mall-category__wrap">
      <view
        class="mall-category__chip {{currentCategory === 'all' ? 'mall-category__chip--active' : ''}}"
        data-id="all"
        bindtap="onCategoryTap"
      >全部</view>
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="mall-category__chip {{currentCategory === item.id ? 'mall-category__chip--active' : ''}}"
        data-id="{{item.id}}"
        bindtap="onCategoryTap"
      >{{item.name}}</view>
    </view>
  </view>
  <view wx:if="{{loading}}" class="mall-loading">
    <view class="mall-skeleton">
      <view class="mall-skeleton__item" wx:for="{{[1,2,3,4,5,6]}}" wx:key="*this">
        <view class="mall-skeleton__thumb"></view>
        <view class="mall-skeleton__info">
          <view class="mall-skeleton__line mall-skeleton__title"></view>
          <view class="mall-skeleton__line mall-skeleton__price"></view>
        </view>
      </view>
    </view>
  </view>
  <view wx:else class="mall-list list-fade-in">
    <view
      class="mall-card"
      wx:for="{{list}}"
      wx:key="id"
      data-id="{{item._id || item.id}}"
      bindtap="goDetail"
    >
      <view class="mall-card__thumb">
        <t-icon name="image" size="64rpx" color="#999" />
      </view>
      <view class="mall-card__main">
        <text class="mall-card__title">{{item.title}}</text>
        <view class="mall-card__meta">
          <text wx:if="{{item.price}}" class="mall-card__price">{{item.price}}{{item.unit}}</text>
          <text class="mall-card__time">{{item.createdAt}}</text>
        </view>
      </view>
      <t-icon name="chevron-right" size="32rpx" class="mall-card__arrow" />
    </view>
    <view wx:if="{{list.length === 0}}" class="mall-empty">暂无信息</view>
    <view wx:if="{{listTotal > maxRender}}" class="mall-more-hint">已显示前 {{maxRender}} 条，共 {{listTotal}} 条，请用搜索或分类缩小范围</view>
  </view>
  <view class="mall-fab" bindtap="goPublish">
    <t-icon name="add" size="48rpx" color="#fff" />
  </view>
</view>
