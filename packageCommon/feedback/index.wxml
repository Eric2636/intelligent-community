<view class="feedback-page">
  <view class="form-container">
    <view class="form-item">
      <view class="form-label">反馈类型</view>
      <t-picker
        value="{{feedbackType}}"
        bind:change="onTypeChange"
        title="选择反馈类型"
        keys="{{ { label: 'label', value: 'value' } }}"
      >
        <t-cell
          title="{{typeLabel || '请选择反馈类型'}}"
          note="点击选择"
          arrow
        />
      </t-picker>
    </view>

    <view class="form-item">
      <view class="form-label">反馈内容</view>
      <t-textarea
        value="{{content}}"
        placeholder="请详细描述您的建议或问题..."
        bind:input="onContentInput"
        maxlength="500"
        autosize
      />
    </view>

    <view class="form-item">
      <view class="form-label">联系方式</view>
      <t-input
        value="{{contact}}"
        placeholder="请输入手机号或邮箱"
        bind:change="onContactInput"
      />
    </view>

    <view class="form-actions">
      <t-button
        theme="primary"
        size="large"
        bind:tap="submit"
        loading="{{submitting}}"
        disabled="{{submitting}}"
      >
        提交反馈
      </t-button>
    </view>
  </view>
</view>
