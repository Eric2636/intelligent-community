<import src="../../templates/forum-list-media.wxml" />
<view class="my-posts-page">
  <t-pull-down-refresh
    value="{{loading}}"
    loadingProps="{{loadingProps}}"
    bind:refresh="onPullDownRefresh"
  >
    <view class="post-list">
      <view class="post-card" wx:for="{{postList}}" wx:key="id" bind:tap="goPost" data-id="{{item.id || item._id}}">
        <view class="post-title">{{item.title}}</view>
        <view class="post-content">{{item.content}}</view>
        <template is="forumListMedia" data="{{item: item}}" />
        <view class="post-meta">
          <text class="time">{{item.createTime}}</text>
          <text class="reply-count">{{item.replyCount}} 回复</text>
        </view>
      </view>
    </view>
    <t-empty wx:if="{{!loading && postList.length === 0}}" description="暂无发布的帖子" />
  </t-pull-down-refresh>
</view>
